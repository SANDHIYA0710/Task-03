# --------------- Section 6 — List Basics (31–35) --------------

# 31 Sum of list
l = [10,20,30,40,50]
sum = 0
for i in l:
    sum += i
print("Sum =", sum)

# 32 Max
max_val = l[0]
for i in l:
    if i > max_val:
        max_val = i
print("Max =", max_val)

# 33 Min
min_val = l[0]
for i in l:
    if i < min_val:
        min_val = i
print("Min =", min_val)

# 34 Count elements
count = 0
for i in l:
    count += 1
print("Total =", count)

# 35 Check element
x = int(input("Enter element: "))
if x in l:
    print("Exists")
else:
    print("Not exists")


# --------------- Section 7 — List Operations (36–40) -------------

l = []

# 36 Append
l.append(10)
l.append(20)
l.append(30)
print(l)

# 37 Insert
l.insert(1,15)
print(l)

# 38 Remove
l.remove(20)
print(l)

# 39 Reverse without reverse()
rev = []
for i in l:
    rev = [i] + rev
print(rev)

# 40 Sort without sort()
for i in range(len(l)):
    for j in range(i+1,len(l)):
        if l[i] > l[j]:
            l[i], l[j] = l[j], l[i]
print("Sorted =", l)


